# Casino API Configuration
# This is an example file showing expected environment variables
# Copy this to .env and configure appropriately for your deployment

# Server Configuration
PORT=3000

# Database Configuration (if added later)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=casino_api
DB_USER=your_db_user
DB_PASS=your_db_password

# API Keys (examples - replace with your actual keys if using external services)
PRAGMATIC_API_KEY=your_pragmatic_api_key_here
PGSOFT_API_KEY=your_pgsoft_api_key_here
NEXUSGGR_API_KEY=your_nexusggr_api_key_here

# JWT Secret for authentication (if authentication is added)
JWT_SECRET=your_jwt_secret_here

# Other sensitive configurations would go here
# REDIS_URL=redis://localhost:6379
# SMTP_SERVER=smtp.example.com
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password